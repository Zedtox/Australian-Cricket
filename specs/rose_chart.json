{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "width": "container",
  "height": 360,
  "config": {
    "background": "transparent",
    "font": "DM Sans",
    "axis": {
      "labelFont": "DM Sans",
      "labelColor": "rgba(232,224,206,0.55)",
      "titleFont": "DM Sans",
      "titleColor": "rgba(232,224,206,0.55)",
      "gridColor": "rgba(255,255,255,0.05)",
      "domainColor": "rgba(255,255,255,0.12)",
      "tickColor": "rgba(255,255,255,0.12)"
    },
    "legend": {
      "labelFont": "DM Sans",
      "labelColor": "rgba(232,224,206,0.75)",
      "titleFont": "DM Sans",
      "titleColor": "rgba(232,224,206,0.55)"
    },
    "view": {
      "stroke": "transparent"
    }
  },
  "description": "Rose chart of Australian win rate by opponent.",
  "data": {
    "url": "data/head_to_head.json"
  },
  "layer": [
    {
      "mark": {
        "type": "arc",
        "innerRadius": 25,
        "stroke": "#060d08",
        "strokeWidth": 1
      },
      "encoding": {
        "theta": {
          "field": "opponent",
          "type": "nominal",
          "sort": null,
          "axis": null
        },
        "radius": {
          "field": "win_rate",
          "type": "quantitative",
          "scale": {
            "domain": [
              0,
              80
            ],
            "range": [
              20,
              150
            ]
          },
          "legend": null
        },
        "color": {
          "field": "win_rate",
          "type": "quantitative",
          "scale": {
            "domain": [
              30,
              55,
              75
            ],
            "range": [
              "#1a5c35",
              "#2d8a52",
              "#f0b429"
            ]
          },
          "legend": {
            "title": "Win %"
          }
        },
        "tooltip": [
          {
            "field": "opponent"
          },
          {
            "field": "matches"
          },
          {
            "field": "wins"
          },
          {
            "field": "win_rate",
            "title": "Win %",
            "format": ".1f"
          }
        ]
      }
    },
    {
      "mark": {
        "type": "text",
        "radius": 168,
        "fontSize": 10,
        "font": "DM Sans",
        "color": "rgba(232,224,206,0.72)"
      },
      "encoding": {
        "theta": {
          "field": "opponent",
          "type": "nominal",
          "sort": null
        },
        "text": {
          "field": "opponent"
        }
      }
    }
  ]
}